@prefix : <http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#> .
@prefix gsp: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix esdir: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#> .
@prefix schema: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix edintinf: <http://vocab.linkeddata.es/datosabiertos/def/urbanismos-infraestructuras/infraestructura#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintagenda: <http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#> .
@base <http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda> .

<http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda> rdf:type owl:Ontology ;
                                                                    owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda/0.1.0> ;
                                                                    <http://purl.org/dc/elements/1.1/creator> "Daniel Doña" ,
                                                                                                              "Edna Ruckhaus" ,
                                                                                                              "Lucía Sánchez" ,
                                                                                                              "Oscar Corcho" ,
                                                                                                              "Socorro Bernardos" ;
                                                                    dcterms:created "2026-05-05" ;
                                                                    dcterms:description "The Agenda ontology represents the agenda of cultural, sporting and social events that take place in the municipality."@es ;
                                                                    dcterms:title <https://creativecommons.org/licenses/by/4.0> ,
                                                                                  "Vocabulario para la representación de la agenda cultural, deportiva y social de un municipio"@es ,
                                                                                  "Vocabulary for the representation of the cultural, sporting and social agenda of a municipality"@en ;
                                                                    <http://purl.org/vocab/vann/preferredNamespacePrefix> "esagenda" ;
                                                                    <http://purl.org/vocab/vann/preferredNamespaceUri> "http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#" ;
                                                                    rdfs:comment "http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/contributor
<http://purl.org/dc/elements/1.1/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/created
<http://purl.org/dc/elements/1.1/created> rdf:type owl:AnnotationProperty ;
                                          rdfs:subPropertyOf dcterms:title .


###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
<http://purl.org/dc/elements/1.1/date> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/identifier
<http://purl.org/dc/elements/1.1/identifier> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#attendanceMode
edintagenda:attendanceMode rdf:type owl:ObjectProperty ;
                           rdfs:domain edintagenda:CityEvent ;
                           rdfs:range [ rdf:type owl:Restriction ;
                                        owl:onProperty skos:inScheme ;
                                        owl:hasValue edintkos:AttendanceMode
                                      ] ;
                           rdfs:comment "Attendance mode, for example, in person, online."@en ,
                                        "Modalidad de asistencia, por ejemplo, presencial, en línea."@es ;
                           rdfs:label "attendance mode"@en ,
                                      "modalidad de asistencia"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#documentation
edintagenda:documentation rdf:type owl:ObjectProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain edintagenda:CityEvent ;
                          rdfs:range schema:DigitalDocument ;
                          rdfs:comment "Documentación asociada a un evento"@es ,
                                       "Documentation associated with an event"@en ;
                          rdfs:label "documentacion"@es ,
                                     "documentation"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#eventStatus
edintagenda:eventStatus rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf owl:topObjectProperty ;
                        rdfs:domain edintagenda:CityEvent ;
                        rdfs:range [ rdf:type owl:Restriction ;
                                     owl:onProperty skos:inScheme ;
                                     owl:hasValue edintkos:EventStatus
                                   ] ;
                        rdfs:comment "Estado de un evento, por ejemplo, activo o cancelado."@es ,
                                     "Status of an event, for example, active or cancelled."@en ;
                        rdfs:label "estado del evento"@es ,
                                   "event status"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#eventType
edintagenda:eventType rdf:type owl:ObjectProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain edintagenda:CityEvent ;
                      rdfs:range [ rdf:type owl:Restriction ;
                                   owl:onProperty skos:inScheme ;
                                   owl:hasValue edintkos:EventType
                                 ] ;
                      rdfs:comment "Tipo de evento que tendrá lugar."@es ,
                                   "Type of event to be held."@en ;
                      rdfs:label "tipo de evento"@es ,
                                 "type of event"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#organizedBy
edintagenda:organizedBy rdf:type owl:ObjectProperty ;
                        rdfs:domain edintagenda:CityEvent ;
                        rdfs:range <http://schema.org/Organization> ;
                        rdfs:comment "Relación entre el evento y la organización que lo gestiona."@es ,
                                     "Relationship between the event and the organization that manages it."@en ;
                        rdfs:label "organizadoPor"@es ,
                                   "organizedBy"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#takesPlace
edintagenda:takesPlace rdf:type owl:ObjectProperty ;
                       rdfs:domain edintagenda:CityEvent ;
                       rdfs:range edintinf:Facility ;
                       rdfs:comment "El lugar en donde se realiza el evento."@es ,
                                    "The venue where the event takes place."@es ;
                       rdfs:label "takes place"@en ,
                                  "tiene lugar"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#workPerformed
edintagenda:workPerformed rdf:type owl:ObjectProperty ;
                          rdfs:domain schema:Event ;
                          rdfs:range schema:CreativeWork ;
                          rdfs:comment "A work performed in some event, for example a play performed in a theater event."@en ,
                                       "Una obra representada en algún evento, por ejemplo, una obra de teatro representada en un evento teatral."@es ;
                          rdfs:label "obra presentada"@es ,
                                     "work performed"@en .


###  http://www.opengis.net/ont/geosparql#hasGeometry
gsp:hasGeometry rdf:type owl:ObjectProperty ;
                rdfs:domain gsp:Feature ;
                rdfs:range gsp:Geometry ;
                <http://purl.org/dc/elements/1.1/contributor> "Matthew Perry" ;
                <http://purl.org/dc/elements/1.1/creator> "OGC GeoSPARQL 1.0 Standard Working Group" ;
                <http://purl.org/dc/elements/1.1/date> "2011-06-16"^^xsd:date ;
                <http://purl.org/dc/elements/1.1/description> """
      A spatial representation for a given feature.
    """@en ;
                rdfs:comment """
      A spatial representation for a given feature.
    """@en ;
                rdfs:isDefinedBy <http://www.opengis.net/ont/geosparql> ,
                                 <http://www.opengis.net/spec/geosparql/1.0> ;
                rdfs:label "hasGeometry"@en ;
                skos:definition """
      A spatial representation for a given feature.
    """@en ;
                skos:prefLabel "hasGeometry"@en .


###  http://www.w3.org/2004/02/skos/core#inScheme
skos:inScheme rdf:type owl:ObjectProperty ;
              rdfs:range skos:ConceptScheme ;
              rdfs:comment "A concept may be a member of more than one concept scheme."@en ;
              rdfs:label "is in scheme"@en .


###  https://schema.org/address
schema:address rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain edintagenda:CityEvent ;
               rdfs:range esdir:DireccionPostal ;
               rdfs:comment "Dirección física del artículo."@es ,
                            "Physical address of the item."@en ;
               rdfs:label "address"@en ,
                          "dirección"@es .


###  https://schema.org/subEvent
schema:subEvent rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain schema:Event ;
                rdfs:range schema:Event ;
                rdfs:comment "An Event that is part of this event."@en ,
                             "Un evento que forma parte de este evento."@es ;
                rdfs:label "sub event"@en ,
                           "sub evento"@es .


###  https://schema.org/superEvent
schema:superEvent rdf:type owl:ObjectProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain schema:Event ;
                  rdfs:range schema:Event ;
                  rdfs:comment "An event that this event is a part of."@en ,
                               "Un acontecimiento del que forma parte este evento."@es ;
                  rdfs:label "super event"@en ,
                             "super evento"@es .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/identifier
dcterms:identifier rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:string .


###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#interior
edintagenda:interior rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain edintagenda:CityEvent ;
                     rdfs:range xsd:boolean ;
                     rdfs:comment "Indica si un evento tiene lugar en un sitio cerrado."@es ,
                                  "Indicates whether an event is taking place in an enclosed location"@en ;
                     rdfs:label "inside"@en ,
                                "interior"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#price
edintagenda:price rdf:type owl:DatatypeProperty ;
                  rdfs:domain edintagenda:CityEvent ;
                  rdfs:range xsd:string ;
                  rdfs:comment "El precio de un evento."@es ,
                               "The price of an event." ;
                  rdfs:label "precio"@es ,
                             "price" .


###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#schedule
edintagenda:schedule rdf:type owl:DatatypeProperty ;
                     rdfs:domain edintagenda:CityEvent ;
                     rdfs:range xsd:string ;
                     rdfs:comment "El cronograma de un evento que especifica  el horario de cada día."@es ,
                                  "The schedule of an event scpecifying the hours each day."@en ;
                     rdfs:label "horario"@es ,
                                "schedule"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructura/equipamiento-municipal#nombre
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructura/equipamiento-municipal#nombre> rdf:type owl:DatatypeProperty ,
                                                                                                                owl:FunctionalProperty ;
                                                                                                       rdfs:range xsd:string ;
                                                                                                       rdfs:comment "Name of the equipment of the municipality where the event will take place."@en ,
                                                                                                                    "Nombre del equipamiento del ayuntamiento donde tendrá lugar el evento."@es ;
                                                                                                       rdfs:label "name"@en ,
                                                                                                                  "nombre"@es .


###  https://schema.org/audience
schema:audience rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain schema:Event ;
                rdfs:range xsd:string ;
                rdfs:comment "El público al que va dirigido el artículo, es decir, el grupo para el que se creó el artículo."@es ,
                             "Intended audience for an item, i.e. the group for whom the item was created."@en ;
                rdfs:label "audience"@en ,
                           "audiencia"@es .


###  https://schema.org/description
schema:description rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty ;
                   rdfs:range xsd:string ;
                   rdfs:comment "A description of the item."@en ,
                                "Una descripción del artículo."@es ;
                   rdfs:label "descripción"@es ,
                              "description"@en .


###  https://schema.org/doorTime
schema:doorTime rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain schema:Event ;
                rdfs:range xsd:dateTime ;
                rdfs:comment "La hora de inicio de la admisión."@es ,
                             "The time admission will commence."@en ;
                rdfs:label "hora de apertura"@es ,
                           "opening time"@en .


###  https://schema.org/encodingFormat
schema:encodingFormat rdf:type owl:DatatypeProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain schema:CreativeWork ;
                      rdfs:range xsd:string ;
                      rdfs:comment "File format type"@en ,
                                   "Tipo del formato del archivo"@es ;
                      rdfs:label "file format"@en ,
                                 "formato archivo"@es .


###  https://schema.org/endDate
schema:endDate rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain schema:Event ;
               rdfs:range xsd:dateTime ;
               rdfs:comment "La fecha y hora de finalización del artículo"@es ,
                            "The end date and time of the item"@en ;
               rdfs:label "end date"@en ,
                          "fecha fin"@es .


###  https://schema.org/eventStatus
schema:eventStatus rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain schema:Event ;
                   rdfs:range xsd:string ;
                   rdfs:comment "An eventStatus of an event represents its status; particularly useful when an event is cancelled or rescheduled."@en ,
                                "El estado de un evento representa su situación; especialmente útil cuando un evento se cancela o se reprograma."@es ;
                   rdfs:label "estado del evento"@es ,
                              "event status"@en .


###  https://schema.org/image
schema:image rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:range xsd:anyURI ;
             rdfs:comment "An image of the item."@en ,
                          "Una imagen del artículo."@es ;
             rdfs:label "image"@en ,
                        "imagen"@es .


###  https://schema.org/isAccessibleForFree
schema:isAccessibleForFree rdf:type owl:DatatypeProperty ,
                                    owl:FunctionalProperty ;
                           rdfs:domain edintagenda:CityEvent ;
                           rdfs:range xsd:boolean ;
                           rdfs:comment "A flag to signal that the item, event, or place is accessible for free."@en ,
                                        "Una bandera para señalar que el artículo, evento o lugar es accesible de forma gratuita."@es ;
                           rdfs:label "es accesible gratis"@es ,
                                      "is accessible free"@en .


###  https://schema.org/maximumAttendeeCapacity
schema:maximumAttendeeCapacity rdf:type owl:DatatypeProperty ,
                                        owl:FunctionalProperty ;
                               rdfs:domain schema:Event ;
                               rdfs:range xsd:integer ;
                               rdfs:comment "El número total de personas que pueden asistir a un evento o local."@es ,
                                            "The total number of individuals that may attend an event or venue."@en ;
                               rdfs:label "capacidad máxima"@es ,
                                          "maximun attendee capacity"@en .


###  https://schema.org/name
schema:name rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:range xsd:string ;
            rdfs:comment "El nombre de un elemento"@es ,
                         "The name of the item."@en ;
            rdfs:label "name" .


###  https://schema.org/startDate
schema:startDate rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain schema:Event ;
                 rdfs:range xsd:dateTime ;
                 rdfs:comment "La fecha y la hora de inicio del artículo"@es ,
                              "The start date and time of the item"@en ;
                 rdfs:label "fecha inicio"@es ,
                            "start date"@en .


###  https://schema.org/typicalAgeRange
schema:typicalAgeRange rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain schema:Event ;
                       rdfs:range xsd:string ;
                       rdfs:comment "El rango de edad típico esperado"@es ,
                                    "The typical expected age range"@en ;
                       rdfs:label "rango de edad"@es ,
                                  "typical age range"@en .


###  https://schema.org/url
schema:url rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:range xsd:anyURI ;
           rdfs:comment "Enlace del artículo"@es ,
                        "URL of the item"@en ;
           rdfs:label "enlace"@es ,
                      "url"@en .


#################################################################
#    Classes
#################################################################

###  http://schema.org/CreativeWork
<http://schema.org/CreativeWork> rdf:type owl:Class ;
                                 rdfs:comment "El tipo más genérico de trabajo creativo, que incluye libros, películas, fotografías, programas informáticos, etc."@es ,
                                              "The most generic kind of creative work, including books, movies, photographs, software programs, etc."@en ;
                                 rdfs:label "Creative work"@en ,
                                            "Trabajo creativo"@es .


###  http://schema.org/Organization
<http://schema.org/Organization> rdf:type owl:Class ;
                                 rdfs:comment "A collection of people organized together into a community or other social, commercial or political structure."@es ,
                                              "a collection of people organized together into a community or other social, commercial or political structure."@en ;
                                 rdfs:label "Organización"@es ,
                                            "Organization"@en .


###  http://schema.org/PostalAddress
<http://schema.org/PostalAddress> rdf:type owl:Class ;
                                  rdfs:comment "Dirección para envío de correo."@es ,
                                               "The mailing address."@en ;
                                  rdfs:label "Dirección postal"@es ,
                                             "Postal address"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#CityEvent
edintagenda:CityEvent rdf:type owl:Class ;
                      rdfs:subClassOf gsp:Feature ,
                                      schema:Event ;
                      rdfs:comment "An event that will take place in a city."@en ,
                                   "Evento que tendrá lugar en una ciudad."@es ;
                      rdfs:label "Evento" .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal
esdir:DireccionPostal rdf:type owl:Class ;
                      rdfs:subClassOf <http://schema.org/PostalAddress> ;
                      rdfs:comment "Dirección postal en España."@es ,
                                   "Postal address in Spain."@en ;
                      rdfs:label "Dirección postal"@es ,
                                 "Postal address"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismos-infraestructuras/infraestructura#Facility
edintinf:Facility rdf:type owl:Class ;
                  rdfs:comment "Hace referencia a edificios de servicios (públicos o privados), zonas de ocio, zonas comerciales o cualquier otro elemento  que afecte directamente a la movilidad, actuando como un foco de atracción de personas o vehículos."@es ,
                               "It refers to service buildings (public or private), leisure areas, commercial areas or any other element that directly affects mobility, acting as a focus of attraction for persons or vehicles."@en ;
                  rdfs:label "Equipamiento"@es ,
                             "Facility"@en .


###  http://www.opengis.net/ont/geosparql#Feature
gsp:Feature rdf:type owl:Class ;
            rdfs:subClassOf gsp:SpatialObject ;
            owl:disjointWith gsp:Geometry ;
            <http://purl.org/dc/elements/1.1/contributor> "Matthew Perry" ;
            <http://purl.org/dc/elements/1.1/creator> "OGC GeoSPARQL 1.0 Standard Working Group" ;
            <http://purl.org/dc/elements/1.1/date> "2011-06-16"^^xsd:date ;
            <http://purl.org/dc/elements/1.1/description> """
      This class represents the top-level feature type. This class is 
      equivalent to GFI_Feature defined in ISO 19156:2011, and it is 
      superclass of all feature types.
    """@en ;
            rdfs:comment """
      This class represents the top-level feature type. This class is 
      equivalent to GFI_Feature defined in ISO 19156:2011, and it is 
      superclass of all feature types.
    """@en ;
            rdfs:isDefinedBy <http://www.opengis.net/ont/geosparql> ,
                             <http://www.opengis.net/ont/gml> ,
                             <http://www.opengis.net/spec/geosparql/1.0> ;
            rdfs:label "Feature"@en ;
            skos:definition """
      This class represents the top-level feature type. This class is 
      equivalent to GFI_Feature defined in ISO 19156:2011, and it is 
      superclass of all feature types.
    """@en ;
            skos:prefLabel "Feature"@en .


###  http://www.opengis.net/ont/geosparql#Geometry
gsp:Geometry rdf:type owl:Class ;
             rdfs:subClassOf gsp:SpatialObject ;
             <http://purl.org/dc/elements/1.1/contributor> "Matthew Perry" ;
             <http://purl.org/dc/elements/1.1/creator> "OGC GeoSPARQL 1.0 Standard Working Group" ;
             <http://purl.org/dc/elements/1.1/date> "2011-06-16"^^xsd:date ;
             <http://purl.org/dc/elements/1.1/description> """
      The class represents the top-level geometry type. This class is 
      equivalent to the UML class GM_Object defined in ISO 19107, and 
      it is superclass of all geometry types.
    """@en ;
             rdfs:comment """
      The class represents the top-level geometry type. This class is 
      equivalent to the UML class GM_Object defined in ISO 19107, and 
      it is superclass of all geometry types.
    """@en ;
             rdfs:isDefinedBy <http://www.opengis.net/ont/geosparql> ,
                              <http://www.opengis.net/ont/gml> ,
                              <http://www.opengis.net/spec/geosparql/1.0> ;
             rdfs:label "Geometry"@en ;
             skos:definition """
      The class represents the top-level geometry type. This class is 
      equivalent to the UML class GM_Object defined in ISO 19107, and 
      it is superclass of all geometry types.
    """@en ;
             skos:prefLabel "Geometry"@en .


###  http://www.opengis.net/ont/geosparql#SpatialObject
gsp:SpatialObject rdf:type owl:Class ;
                  <http://purl.org/dc/elements/1.1/contributor> "Matthew Perry" ;
                  <http://purl.org/dc/elements/1.1/creator> "OGC GeoSPARQL 1.0 Standard Working Group" ;
                  <http://purl.org/dc/elements/1.1/date> "2011-06-16"^^xsd:date ;
                  <http://purl.org/dc/elements/1.1/description> """
      The class spatial-object represents everything that can have 
      a spatial representation. It is superclass of feature and geometry.
    """@en ;
                  rdfs:comment """
      The class spatial-object represents everything that can have 
      a spatial representation. It is superclass of feature and geometry.
    """@en ;
                  rdfs:isDefinedBy <http://www.opengis.net/ont/geosparql> ,
                                   <http://www.opengis.net/ont/gml> ,
                                   <http://www.opengis.net/spec/geosparql/1.0> ;
                  rdfs:label "SpatialObject"@en ;
                  skos:definition """
      The class spatial-object represents everything that can have 
      a spatial representation. It is superclass of feature and geometry.
    """@en ;
                  skos:prefLabel "SpatialObject"@en .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class ;
             owl:disjointWith skos:ConceptScheme ;
             rdfs:comment "An abstract idea or notion; a unit of thought."@en ;
             rdfs:label "Concept"@en .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
skos:ConceptScheme rdf:type owl:Class ;
                   rdfs:comment "A set of concepts, optionally including statements about semantic relationships between those concepts."@en ;
                   rdfs:label "Concept Scheme"@en .


###  https://schema.org/CreativeWork
schema:CreativeWork rdf:type owl:Class ;
                    rdfs:comment "El tipo más genérico de trabajo creativo, que incluye libros, películas, fotografías, programas de software, etc."@es ,
                                 "The most generic kind of creative work, including books, movies, photographs, software programs, etc."@en ;
                    rdfs:label "Creative Work"@en ,
                               "Trabajo creativo"@es .


###  https://schema.org/DigitalDocument
schema:DigitalDocument rdf:type owl:Class ;
                       rdfs:subClassOf schema:CreativeWork ;
                       rdfs:comment "An electronic file or document."@en ,
                                    "Un archivo o documento electrónico."@es ;
                       rdfs:label "Digital Document"@en ,
                                  "Documento digital"@es .


###  https://schema.org/Event
schema:Event rdf:type owl:Class ;
             rdfs:comment "An event happening at a certain time and location, such as a concert, lecture, or festival."@en ,
                          "Un evento que tiene lugar a una hora y en un lugar determinados, como un concierto, una conferencia o un festival."@es ;
             rdfs:label "Event" .


