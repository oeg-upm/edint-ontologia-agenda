        <rdfs:comment xml:lang="es">The venue where the event takes place.</rdfs:comment>
        <rdfs:label xml:lang="en">takes place</rdfs:label>
        <rdfs:label xml:lang="es">tiene lugar</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#workPerformed -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#workPerformed">
        <rdfs:domain rdf:resource="https://schema.org/Event"/>
        <rdfs:range rdf:resource="https://schema.org/CreativeWork"/>
        <rdfs:comment xml:lang="en">A work performed in some event, for example a play performed in a theater event.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una obra representada en algún evento, por ejemplo, una obra de teatro representada en un evento teatral.</rdfs:comment>
        <rdfs:label xml:lang="es">obra presentada</rdfs:label>
        <rdfs:label xml:lang="en">work performed</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasGeometry -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasGeometry">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <dc:contributor>Matthew Perry</dc:contributor>
        <dc:creator>OGC GeoSPARQL 1.0 Standard Working Group</dc:creator>
        <dc:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2011-06-16</dc:date>
        <dc:description xml:lang="en">
      A spatial representation for a given feature.
    </dc:description>
        <rdfs:comment xml:lang="en">
      A spatial representation for a given feature.
    </rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0"/>
        <rdfs:label xml:lang="en">hasGeometry</rdfs:label>
        <skos:definition xml:lang="en">
      A spatial representation for a given feature.
    </skos:definition>
        <skos:prefLabel xml:lang="en">hasGeometry</skos:prefLabel>
    </owl:ObjectProperty>
    


