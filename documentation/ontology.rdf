        <rdfs:comment xml:lang="en">Relationship between the event and the organization that manages it.</rdfs:comment>
        <rdfs:label xml:lang="es">organizadoPor</rdfs:label>
        <rdfs:label xml:lang="en">organizedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#takesPlace -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#takesPlace">
