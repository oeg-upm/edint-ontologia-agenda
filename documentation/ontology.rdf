        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">El cronograma de un evento que especifica  el horario de cada día.</rdfs:comment>
        <rdfs:comment xml:lang="en">The schedule of an event scpecifying the hours each day.</rdfs:comment>
        <rdfs:label xml:lang="es">horario</rdfs:label>
        <rdfs:label xml:lang="en">schedule</rdfs:label>
    </owl:DatatypeProperty>
    


