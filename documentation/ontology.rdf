        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">An image of the item.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una imagen del artículo.</rdfs:comment>
        <rdfs:label xml:lang="en">image</rdfs:label>
        <rdfs:label xml:lang="es">imagen</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://schema.org/isAccessibleForFree -->


    <owl:DatatypeProperty rdf:about="https://schema.org/isAccessibleForFree">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
