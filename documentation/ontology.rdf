        <dc:creator>Lucía Sánchez</dc:creator>
        <dc:creator>Oscar Corcho</dc:creator>
        <dc:creator>Socorro Bernardos</dc:creator>
        <terms:description xml:lang="es">The Agenda ontology represents the agenda of cultural, sporting and social events that take place in the municipality.</terms:description>
        <terms:title rdf:resource="https://creativecommons.org/licenses/by/4.0"/>
        <terms:title xml:lang="es">Vocabulario para la representación de la agenda cultural, deportiva y social de un municipio</terms:title>
        <terms:title xml:lang="en">Vocabulary for the representation of the cultural, sporting and social agenda of a municipality</terms:title>
        <vann:preferredNamespacePrefix>esagenda</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#</vann:preferredNamespaceUri>
        <rdfs:comment>http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda</rdfs:comment>
    </owl:Ontology>
    


