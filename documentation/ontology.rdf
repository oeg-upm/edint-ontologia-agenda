    <!-- http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#attendanceMode -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#attendanceMode">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#CityEvent"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/AttendanceMode"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Attendance mode, for example, in person, online.</rdfs:comment>
        <rdfs:comment xml:lang="es">Modalidad de asistencia, por ejemplo, presencial, en línea.</rdfs:comment>
        <rdfs:label xml:lang="en">attendance mode</rdfs:label>
        <rdfs:label xml:lang="es">modalidad de asistencia</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#documentation -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#documentation">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#CityEvent"/>
        <rdfs:range rdf:resource="https://schema.org/DigitalDocument"/>
        <rdfs:comment xml:lang="es">Documentación asociada a un evento</rdfs:comment>
        <rdfs:comment xml:lang="en">Documentation associated with an event</rdfs:comment>
        <rdfs:label xml:lang="es">documentacion</rdfs:label>
        <rdfs:label xml:lang="en">documentation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#eventStatus -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#eventStatus">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#CityEvent"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/EventStatus"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Estado de un evento, por ejemplo, activo o cancelado.</rdfs:comment>
        <rdfs:comment xml:lang="en">Status of an event, for example, active or cancelled.</rdfs:comment>
        <rdfs:label xml:lang="es">estado del evento</rdfs:label>
        <rdfs:label xml:lang="en">event status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#eventType -->


