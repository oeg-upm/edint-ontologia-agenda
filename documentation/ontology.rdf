    <owl:Ontology rdf:about="http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda">
        <owl:versionIRI rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda/0.1.0"/>
