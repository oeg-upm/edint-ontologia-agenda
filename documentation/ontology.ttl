@prefix : <http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#> .

<http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda> rdf:type owl:Ontology ;
                                                                    owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda/0.1.0> ;
                                                                    <http://purl.org/dc/elements/1.1/creator> "Daniel Doña" ,
                                                                                                              "Edna Ruckhaus" ,
                                                                                                              "Lucía Sánchez" ,
                                                                                                              "Oscar Corcho" ,
                                                                                                              "Socorro Bernardos" ;
                                                                    <http://purl.org/dc/terms/description> "The Agenda ontology represents the agenda of cultural, sporting and social events that take place in the municipality."@es ;
                                                                    <http://purl.org/dc/terms/title> <https://creativecommons.org/licenses/by/4.0> ,
                                                                                                     "Vocabulario para la representación de la agenda cultural, deportiva y social de un municipio"@es ,
                                                                                                     "Vocabulary for the representation of the cultural, sporting and social agenda of a municipality"@en ;
                                                                    <http://purl.org/vocab/vann/preferredNamespacePrefix> "esagenda" ;
                                                                    <http://purl.org/vocab/vann/preferredNamespaceUri> "http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda#" ;
                                                                    rdfs:comment "http://vocab.linkeddata.es/datosabiertos/def/cultura-ocio/agenda" .

